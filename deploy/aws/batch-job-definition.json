{
  "jobDefinitionName": "aortacfd-cfd-run",
  "type": "container",
  "containerProperties": {
    "image": "774222655637.dkr.ecr.eu-north-1.amazonaws.com/aortacfd-agent:latest",
    "vcpus": 8,
    "memory": 16384,
    "command": [
      "bash", "-c",
      "source /opt/openfoam12/etc/bashrc && python /app/deploy/aws/batch_entrypoint.py"
    ],
    "environment": [
      { "name": "S3_BUCKET", "value": "aortacfd-runs" },
      { "name": "AWS_DEFAULT_REGION", "value": "eu-north-1" }
    ],
    "jobRoleArn": "arn:aws:iam::774222655637:role/aortacfd-batch-role",
    "logConfiguration": {
      "logDriver": "awslogs",
      "options": {
        "awslogs-group": "/aws/batch/aortacfd",
        "awslogs-region": "eu-north-1",
        "awslogs-stream-prefix": "cfd"
      }
    }
  },
  "retryStrategy": {
    "attempts": 1
  },
  "timeout": {
    "attemptDurationSeconds": 7200
  }
}
